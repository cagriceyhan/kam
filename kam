    if d and m and y:
        raw_data.extend([d+m+y, y, y[-2:], d+m, m+d, d+"."+m+"."+y])

    use_num = input(f"{BOLD}{t['q_num']}{RESET}").lower() in ['e','y']
    use_spec = input(f"{BOLD}{t['q_spec']}{RESET}").lower() in ['e','y']
