    except ValueError:
        depth = 5
    out_name = input(f"{BOLD}{t['q_file']}{RESET}").strip() or "kam_wordlist.txt"

    nums = ['123', '1903', '1905', '1907', '2026', '0', '1'] if use_num else ['']
    specs = ['!', '@', '#', '*', '?', '.', '_', '<', '>', '+', '^', '%','&','/','(', ')','='] if use_spec else ['']
    templates = ['Sifre', 'Password', 'Admin', 'Login', 'root', 'toor', 'abc', 'asd', 'asdf','qwe', 'zxc','qwer'] if use_templates else []
    
    all_seeds = set(raw_data)
    if use_leet: all_seeds.update([leet_engine(x) for x in raw_data])
    if use_templates: all_seeds.update(templates)

    seeds = list(all_seeds)
    max_comb = 1 if depth < 5 else 2 if depth < 9 else 3
    final_list = set()

    print(t["working"])
    for r in range(1, max_comb + 1):
        for combo in itertools.permutations(seeds, r):
            base = "".join(combo)
            final_list.update([base, base.lower(), base.upper(), base.capitalize()])
            if depth > 2:
                for n in nums: final_list.add(f"{base}{n}")
                for s in specs: final_list.add(f"{base}{s}")
                if depth > 6:
                    for n, s in itertools.product(nums, specs):
                        final_list.add(f"{base}{n}{s}")

    with open(out_name, "w", encoding="utf-8") as f:
        for word in sorted(final_list):
            if len(word) >= 4:
                f.write(generate_hash(word, hash_mode) + "\n")

    print(t["success"])
    print(f"{CYAN}{t['count']}{len(final_list)}")
    print(f"{t['path']}{os.path.abspath(out_name)}{RESET}")

