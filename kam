def normalize_turkish(text):
    mapping = {'Г§':'c','ГҮ':'C','Дҹ':'g','Дһ':'G','Дұ':'i','I':'I','Д°':'i','Г¶':'o','Г–':'O','Еҹ':'s','Еһ':'S','Гј':'u','Гң':'U'}
    for tr, en in mapping.items():
        text = text.replace(tr, en)
    return text

def leet_engine(text):
    rep = {'a':'4','e':'3','i':'1','o':'0','s':'5','t':'7','b':'8','g':'9'}
    return "".join(rep.get(c.lower(), c) for c in text)

def generate_hash(text, mode):
    if mode == "1": return hashlib.md5(text.encode()).hexdigest()
    if mode == "2": return hashlib.sha1(text.encode()).hexdigest()
    if mode == "3": return hashlib.sha256(text.encode()).hexdigest()
    return text

def apply_smart_filters(wordlist, lang):
    print(f"\n{YELLOW}--- {'Filtreleme SeГ§enekleri' if lang=='TR' else 'Filtering Options'} ---{RESET}")
    min_l = int(input("Minimum karakter uzunluДҹu (Atlamak iГ§in 0): " if lang=="TR" else "Min length (0 to skip): ") or 0)
    must_num = input("Sadece iГ§inde rakam olanlarДұ tut? (e/h): " if lang=="TR" else "Keep only with numbers? (y/n): ").lower() in ['e','y']
    
    filtered = set()
    for w in wordlist:
        if len(w) >= min_l:
            if must_num:
                if any(char.isdigit() for char in w):
                    filtered.add(w)
            else:
                filtered.add(w)
    return filtered

