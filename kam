        "q_temp": "YaygДұn Еҹifre kalДұplarДұ eklensin mi? (e/h): " if lang=="TR" else "Use common templates? (y/n): ",
        
        "q_hash": f"\n{CYAN}--- ГҮДұktДұ FormatДұ ---\n0: DГјz Metin | 1: MD5 | 2: SHA1 | 3: SHA256\nSeГ§iminiz: {RESET}" if lang=="TR" else f"\n{CYAN}--- Output Format ---\n0: Plain Text | 1: MD5 | 2: SHA1 | 3: SHA256\nChoice: {RESET}",
