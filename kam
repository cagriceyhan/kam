        "q_file": "Dosya adДұ: " if lang=="TR" else "Filename: ",
        "working": f"\n{GREEN}[*] Motor Г§alДұЕҹДұyor, lГјtfen bekleyin...{RESET}" if lang=="TR" else f"\n{GREEN}[*] Engine running, please wait...{RESET}",
        "success": f"\n{GREEN}{BOLD}[+] Д°Еҹlem BaЕҹarДұlДұ!{RESET}" if lang=="TR" else f"\n{GREEN}{BOLD}[+] Success!{RESET}",
        "count": "Toplam Kelime: " if lang=="TR" else "Total Words: ",
        "path": "KayДұt Yolu: " if lang=="TR" else "Path: "
    }

    print(t["warn"])

    fields = ["Ad", "Soyad", "EЕҹinin AdДұ", "Evcil HayvanДұ", "ГҮocuДҹunun AdДұ", "KullanДұcДұ AdДұ", "Гңlke", "Еһehir", "Plaka", "TakДұm", "UДҹurlu Rakam"] if lang == "TR" else ["First Name", "Last Name", "Spouse Name", "Pet Name", "Child Name", "Username", "Country", "City", "Plate Code", "Team", "Lucky Number"]

    raw_data = []
    for f in fields:
        val = input(f"{BLUE}{f}: {RESET}").strip().replace(" ", "")
        if val:
            raw_data.append(val)
            norm = normalize_turkish(val)
            if norm != val: raw_data.append(norm)

    print(t["date_head"])
